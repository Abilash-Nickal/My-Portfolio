rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read for any uploaded image
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Allow uploads/deletions only by authenticated admins
    match /gallery/{imageId} {
      allow write: if request.auth != null;
    }
    match /projects/{imageId} {
      allow write: if request.auth != null;
    }
  }
}
