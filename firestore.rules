rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Portfolio data - public read, authenticated write
    match /projects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /experience/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /education/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /skills/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /about/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact messages - public create, authenticated read/delete
    match /messages/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
  }
}
